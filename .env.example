# ─────────────────────────────────────────────────────────────────────────────
# Urban Assist — Environment Variables Template
#
# Copy this file to `.env` inside each app that needs it:
#   cp .env.example apps/customer/.env
#   cp .env.example apps/provider/.env
#   cp .env.example apps/admin/.env
#
# ⚠️  Never commit real keys. The root .env.example is the only env file
#     that should be tracked in git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Required. Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-side only — never expose to browser

# ── Firebase (Push Notifications) ────────────────────────────────────────────
# Optional. Only needed if you want FCM push notifications.
# Get from: https://console.firebase.google.com → Project Settings → General
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=     # Cloud Messaging → Web Push Certificates
FIREBASE_SERVICE_ACCOUNT_JSON=      # Service account JSON (stringified) — server only
FCM_SERVER_KEY=                     # FCM Legacy key — used by notification-dispatch edge function

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for payments. Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=                  # Server-side only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=              # From Stripe webhook endpoint settings
STRIPE_CONNECT_CLIENT_ID=           # For Stripe Connect (provider payouts)

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Optional. Used for rate-limiting and caching. Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google Maps / Address Lookup ──────────────────────────────────────────────
# Optional. Required for map views and address autocomplete.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
POSTCODE_LOOKUP_API_KEY=            # UK postcode validation (e.g. postcodes.io — free, no key needed)

# ── Support ─────────────────────────────────────────────────────────────────────
# Optional. Webhook URL for support ticket notifications.
SUPPORT_NOTIFICATION_WEBHOOK=

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                # e.g. http://localhost:3000 in dev
NEXT_PUBLIC_DEFAULT_CURRENCY=GBP
NEXT_PUBLIC_VAT_RATE=0.20           # 20% UK VAT
